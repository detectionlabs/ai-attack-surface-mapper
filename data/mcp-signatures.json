  "a2a_protocol_indicators": {
    "name": "Agent2Agent (A2A)",
    "vendor": "Google / Linux Foundation",
    "version": "0.3",
    "discovery_path": "/.well-known/agent-card.json",
    "protocols": ["HTTP", "gRPC"],
    "notes": "Look for /.well-known/agent-card.json requests in HTTP logs. Indicates agent-to-agent communication. Complementary to MCP."
  }
