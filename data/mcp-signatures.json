{
  "_metadata": {
    "description": "Argus MCP Detection Signatures — config paths, process patterns, network indicators, and registry platforms for MCP server detection",
    "last_updated": "2026-03-28",
    "version": "1.0.0"
  },
  "mcp_config_paths": {
    "claude_desktop": {
      "macos": "~/Library/Application Support/Claude/claude_desktop_config.json",
      "windows": "%APPDATA%\\Claude\\claude_desktop_config.json",
      "format": "mcpServers JSON object",
      "file_extension_bundles": ".mcpb (formerly .dxt)"
    },
    "claude_code": {
      "global": "~/.claude.json",
      "project": ".mcp.json",
      "settings": "~/.claude/settings.json",
      "cli_command": "claude mcp add <name>"
    },
    "cursor": {
      "global": "~/.cursor/mcp.json",
      "project": ".cursor/mcp.json",
      "settings_ui": "Settings > Features > MCP",
      "transports": ["stdio", "sse", "streamable-http"]
    },
    "windsurf": {
      "macos_linux": "~/.codeium/windsurf/mcp_config.json",
      "windows": "%USERPROFILE%\\.codeium\\windsurf\\mcp_config.json"
    },
    "vscode_copilot": {
      "workspace": ".vscode/mcp.json",
      "user_settings": "settings.json (github.copilot.chat.mcp.servers)",
      "notes": "MCP tools only work in Copilot Agent mode"
    },
    "chatgpt_desktop": {
      "notes": "MCP configured via developer mode. Plugins can package MCP server configurations."
    }
  },
  "mcp_process_patterns": {
    "npm_based": [
      "npx @modelcontextprotocol/",
      "npx -y @modelcontextprotocol/",
      "npx mcp-server-",
      "npx @smithery/",
      "node mcp-server",
      "node .*/mcp"
    ],
    "python_based": [
      "uvx mcp-server-",
      "python -m mcp_server",
      "uvicorn.*mcp",
      "uv run mcp-server-",
      "pip install mcp",
      "pip install @modelcontextprotocol"
    ],
    "docker_based": [
      "docker run.*mcp",
      "docker compose.*mcp"
    ],
    "direct_executables": [
      "mcp-server-*",
      "mcp_server_*",
      "smithery"
    ]
  },
  "mcp_network_indicators": {
    "local_transports": {
      "stdio": "No network traffic — communicates via stdin/stdout",
      "notes": "stdio servers are invisible to network monitoring; detect via process creation events"
    },
    "remote_transports": {
      "sse": {
        "protocol": "HTTP with Server-Sent Events",
        "content_type": "text/event-stream",
        "notes": "Long-lived HTTP connections"
      },
      "streamable_http": {
        "protocol": "HTTP POST/GET with streaming",
        "notes": "Newer transport, replacing SSE in MCP v1.27+"
      }
    },
    "common_hosting_patterns": [
      "*.azurewebsites.net",
      "*.ngrok.io",
      "*.ngrok-free.app",
      "*.run.app",
      "*.lambda-url.*.on.aws",
      "*.execute-api.*.amazonaws.com",
      "*.railway.app",
      "*.fly.dev",
      "*.render.com",
      "*.vercel.app",
      "*.workers.dev",
      "*.deno.dev"
    ]
  },
