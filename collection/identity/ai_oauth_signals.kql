// === Argus AI Identity Detection — last updated 2026-03-28 ===
let ai_apps = dynamic([
    // Coding Assistants
    "GitHub Copilot","GitHub Copilot Chat","Microsoft Copilot","Microsoft 365 Copilot",
    "Cursor","Codeium","Windsurf","Tabnine","Devin",
    "Sourcegraph","Cody","Qodo","Codium","Augment Code",
    "Gemini Code Assist","Google AI Studio",
    "Amazon Q","Amazon Q Developer","AWS CodeWhisperer",
    // AI Chatbots & Assistants
    "ChatGPT","OpenAI","Azure OpenAI","Claude","Anthropic","Grok","xAI",
    "Perplexity","Qwen","Alibaba Cloud","Tongyi Qianwen",
    // App Builders
    "Replit","Lovable",
    // Productivity AI
    "Notion AI","Notion","Grammarly","Jasper","Copy.ai","Midjourney","Runway",
    // MCP & Automation Platforms
    "Zapier","Composio","Smithery"
]);
let ConsentGrants = AuditLogs
| where OperationName in (
    "Consent to application",
    "Add app role assignment to service principal",
    "Add delegated permission grant"
  )
| extend
    AppName  = tostring(TargetResources[0].displayName),
    UPN      = tostring(InitiatedBy.user.userPrincipalName)
| where AppName has_any (ai_apps)
| extend SignalType = "ConsentGrant", Source = "AzureAD_AuditLogs"
| project TimeGenerated, UPN, AppName, SignalType, Source;
let SSOSignIns = SigninLogs
| where AppDisplayName has_any (ai_apps)
| extend SignalType = "SSOSignIn", Source = "SigninLogs"
| project TimeGenerated, UPN = UserPrincipalName, AppName = AppDisplayName, SignalType, Source;
let OktaGrants = OktaSystemLog_CL
| where eventType_s in ("app.oauth2.token.grant","user.authentication.sso")
    and displayMessage_s has_any (ai_apps)
| extend SignalType = "OktaOAuthGrant", Source = "Okta"
| project TimeGenerated, UPN = actor_alternateId_s, AppName = displayMessage_s, SignalType, Source;
union ConsentGrants, SSOSignIns, OktaGrants
| summarize
    GrantCount = count(),
    Users      = make_set(UPN),
    FirstSeen  = min(TimeGenerated),
    LastSeen   = max(TimeGenerated)
    by AppName, SignalType, Source
| order by GrantCount desc
